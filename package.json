{
  "name": "silklearn-website",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=22 <26"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "audit:site": "pnpm exec unlighthouse-ci --site http://localhost:3000 --root . --sitemaps http://localhost:3000/sitemap.xml --mobile --throttle --samples 2 --no-cache --disable-dynamic-sampling --exclude-urls '/studio/.*' --output-path .tmp/unlighthouse",
    "audit:site:desktop": "pnpm exec unlighthouse-ci --site http://localhost:3000 --root . --sitemaps http://localhost:3000/sitemap.xml --desktop --throttle --samples 2 --no-cache --disable-dynamic-sampling --exclude-urls '/studio/.*' --output-path .tmp/unlighthouse-desktop",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.3",
    "@sanity/vision": "^5.13.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.14.2",
    "lenis": "^1.3.18",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.511.0",
    "motion": "^12.35.1",
    "next": "^16.0.0",
    "next-sanity": "^12.1.1",
    "postgres": "^3.4.7",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sanity": "^5.13.0",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.8",
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@unlighthouse/cli": "^0.17.7",
    "eslint": "^9.38.0",
    "eslint-config-next": "^16.0.0",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.9.3"
  }
}