NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Optional: set this to your production domain in Vercel if you want
# metadata and canonical URLs to use a stable host.
# Example: https://silklearn.com

NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Optional: override the default API version (default: 2026-03-27)
# NEXT_PUBLIC_SANITY_API_VERSION=2026-03-27
# Required for Sanity Studio write operations
SANITY_API_TOKEN=

# Analytics / messaging
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_INTERCOM_APP_ID=

# Local Postgres for waitlist capture
POSTGRES_PORT=5434

# For Vercel, this must point to a hosted Postgres instance.
DATABASE_URL=postgresql://silklearn:silklearn@localhost:${POSTGRES_PORT}/silklearn_website
